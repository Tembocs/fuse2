// Fuse Full stdlib surface for channels.
//
// Stage 1 currently lowers channel operations directly in the backend/runtime.
// This file exists so the documented stdlib/full surface is present in the repo
// and parseable by the current frontend while execution work continues.

@value
data class Chan() { }

pub fn Chan.new() -> Chan => Chan()

pub fn Chan.bounded(capacity: Int) -> Chan => Chan()

pub fn Chan.send(ref self, value: Int) { }

pub fn Chan.recv(ref self) -> Int => 0
