extern fn cranelift_ffi_module_finish(ffiModule: Int, pathPtr: String, pathLen: Int) -> Int
extern fn cranelift_ffi_module_free(ffiModule: Int) -> Int

// ---------------------------------------------------------------------------
// Public module lifecycle wrappers (W7.2)
// ---------------------------------------------------------------------------

pub fn createModule() -> Int {
  cranelift_ffi_module_new()
}

pub fn finishModule(ffiModule: Int, outputPath: String) -> Int {
  cranelift_ffi_module_finish(ffiModule, outputPath, outputPath.len())
}
