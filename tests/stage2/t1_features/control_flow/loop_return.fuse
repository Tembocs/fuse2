// EXPECTED OUTPUT:
// found 3

fn findThree() -> Int {
  var i = 0
  loop {
    if i == 3 { return i }
    i = i + 1
  }
  // Unreachable — loop always returns above, but checker requires
  // a trailing expression matching the return type (see learning.md).
  0
}

@entrypoint
fn main() {
  println(f"found {findThree()}")
}
