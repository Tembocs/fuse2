// EXPECTED OUTPUT:
// circle with radius 5
// rect 3 x 4

enum Shape {
  Circle(Int),
  Rect(Int, Int)
}

@entrypoint
fn main() {
  val s1 = Shape.Circle(5)
  match s1 {
    Shape.Circle(r) => println(f"circle with radius {r}"),
    Shape.Rect(w, h) => println(f"rect {w} x {h}")
  }
  val s2 = Shape.Rect(3, 4)
  match s2 {
    Shape.Circle(r) => println(f"circle with radius {r}"),
    Shape.Rect(w, h) => println(f"rect {w} x {h}")
  }
}
