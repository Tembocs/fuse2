// EXPECTED OUTPUT:
// circle with radius 5
// rect area

enum Shape {
  Circle(Int),
  Rect(Int)
}

@entrypoint
fn main() {
  val s1 = Shape.Circle(5)
  match s1 {
    Shape.Circle(r) => println(f"circle with radius {r}"),
    Shape.Rect(w) => println(f"rect with width {w}")
  }
  val s2 = Shape.Rect(3)
  match s2 {
    Shape.Circle(r) => println(f"circle with radius {r}"),
    Shape.Rect(_) => println("rect area")
  }
}
