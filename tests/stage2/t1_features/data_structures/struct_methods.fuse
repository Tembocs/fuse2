// EXPECTED OUTPUT:
// 1
// 2

struct Counter {
  var count: Int

  fn getCount(ref self) -> Int {
    self.count
  }
}

fn Counter.increment(mutref self) {
  self.count = self.count + 1
}

@entrypoint
fn main() {
  var c = Counter(0)
  c.increment()
  println(c.getCount())
  c.increment()
  println(c.getCount())
}
