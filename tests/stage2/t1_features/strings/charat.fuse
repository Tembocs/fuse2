// EXPECTED OUTPUT:
// h
// e
// l

import stdlib.core.string

@entrypoint
fn main() {
  val s = "hello"
  val chars = s.chars()
  match chars.get(0) {
    Some(c) => println(c),
    None => {}
  }
  match chars.get(1) {
    Some(c) => println(c),
    None => {}
  }
  match chars.get(2) {
    Some(c) => println(c),
    None => {}
  }
}
