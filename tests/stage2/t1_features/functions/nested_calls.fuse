// EXPECTED OUTPUT:
// 14

fn addOne(n: Int) -> Int => n + 1
fn double(n: Int) -> Int => n * 2
fn square(n: Int) -> Int => n * n

@entrypoint
fn main() {
  // square(addOne(2)) = square(3) = 9... let's do double(addOne(double(3)))
  // double(3) = 6, addOne(6) = 7, double(7) = 14
  println(double(addOne(double(3))))
}
