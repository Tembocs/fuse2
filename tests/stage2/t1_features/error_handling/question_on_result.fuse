// EXPECTED OUTPUT:
// Ok(20)
// Err(parse failed)

fn parse(s: String) -> Result<Int, String> {
  if s == "10" { Ok(10) } else { Err("parse failed") }
}

fn double(s: String) -> Result<Int, String> {
  val n = parse(s)?
  Ok(n * 2)
}

@entrypoint
fn main() {
  println(double("10"))
  println(double("bad"))
}
