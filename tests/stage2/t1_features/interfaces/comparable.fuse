// EXPECTED OUTPUT:
// -10
// 10

data class Score(val value: Int) implements Comparable

fn Score.compareTo(ref self, ref other: Score) -> Int {
  self.value - other.value
}

@entrypoint
fn main() {
  val a = Score(10)
  val b = Score(20)
  println(a.compareTo(ref b))
  println(b.compareTo(ref a))
}
