// EXPECTED OUTPUT:
// received: 1
// received: 2
// received: 3
// done

@entrypoint
fn main() {
  val ch = Chan::<Int>.new()
  spawn {
    ch.send(1)
    ch.send(2)
    ch.send(3)
    ch.close()
  }
  var running = true
  while running {
    val msg = ch.tryRecv()
    match msg {
      Some(value) => println(f"received: {value}"),
      None => { running = false }
    }
  }
  println("done")
}
