// EXPECTED OUTPUT:
// using r
// [del] r
// step 2
// defer B
// defer A

@value
data class Res(val name: String) {
  fn __del__(owned self) {
    println(f"[del] {self.name}")
  }
}

@entrypoint
fn main() {
  defer println("defer A")
  defer println("defer B")
  val r = Res("r")
  println(f"using {r.name}")
  // r ASAP destroyed here
  println("step 2")
  // defers fire in LIFO at function exit
}
