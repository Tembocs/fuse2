// EXPECTED OUTPUT:
// inside: r
// [del] r
// after call

@value
data class Res(val name: String) {
  fn __del__(owned self) {
    println(f"[del] {self.name}")
  }
}

fn process(owned r: Res) {
  println(f"inside: {r.name}")
  // r last used above — destroyed here inside callee
}

@entrypoint
fn main() {
  val r = Res("r")
  process(move r)
  println("after call")
}
