// EXPECTED OUTPUT:
// using r
// [del] r
// after

@value
data class Res(val name: String) {
  fn __del__(owned self) {
    println(f"[del] {self.name}")
  }
}

@entrypoint
fn main() {
  val r = Res("r")
  println(f"using {r.name}")
  // r is not used after this — ASAP destroys it here
  println("after")
}
