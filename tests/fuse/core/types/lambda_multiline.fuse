// EXPECTED OUTPUT:
// 120
fn apply(n: Int, f: fn(Int) -> Int) -> Int {
  return f(n)
}

@entrypoint
fn main() {
  val factorial = apply(5, fn(n: Int) -> Int {
    var result = 1
    var i = 1
    while i <= n {
      result = result * i
      i = i + 1
    }
    return result
  })
  println(factorial)
}
